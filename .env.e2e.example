# URL de la app (local o Vercel preview)
E2E_BASE_URL=http://localhost:5173

# Supabase (mismo proyecto que la app)
# IMPORTANTE: usar la legacy service_role JWT (empieza con eyJ...), NO la sb_secret_.
# En Dashboard → Settings → API → pestaña "Legacy API Keys" → service_role
E2E_SUPABASE_URL=https://TU_PROYECTO.supabase.co
E2E_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key
VITE_HCAPTCHA_SITE_KEY=tu_site_key

# Contraseña compartida para usuarios E2E creados en runtime
E2E_TEST_PASSWORD=OrvalyaE2E2026!

# Admin temporal E2E (lo crea global-setup.ts; no usar cuenta Google OAuth)
E2E_ADMIN_EMAIL=admin-test-e2e@orvalya.com
E2E_ADMIN_PASSWORD=AdminE2E2026!

# RUT ya registrado en BD (para test de duplicado; debe existir en tabla contratantes)
E2E_EXISTING_RUT=123456789012

# Obtener service role: Supabase Dashboard → Project Settings → API → service_role (secret)
# Obtener admin: usuario existente con perfiles.es_admin = true
